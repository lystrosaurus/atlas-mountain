# Local development configuration template
# Copy this file to config/application-local.yml and customize it
# DO NOT commit config/application-local.yml - it contains local credentials

spring:
  application:
    name: atlas-mountain
  datasource:
    url: jdbc:mysql://localhost:3306/atlas_mountain?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: atlas
    password: atlas
    driver-class-name: com.mysql.cj.jdbc.Driver
  flyway:
    enabled: true
    locations:
      - classpath:db/migration
      - filesystem:dev/db/local
  data:
    redis:
      host: localhost
      port: 6379

server:
  port: 8080

# Rate limiting
ratelimit:
  enabled: true

# CDC binlog capture (disabled by default)
cdc:
  enabled: false
  host: localhost
  port: 3306
  username: root
  password: root
  database: atlas_mountain
  server-id: 1001
  keep-alive: true
  keep-alive-interval: 60000
  heartbeat-interval: 30000
  connect-timeout: 3000
  max-retries: 10
  initial-retry-interval-ms: 1000
  max-retry-interval-ms: 30000
